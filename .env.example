# =============================================================================
# MinusX Unified Environment Configuration
# =============================================================================
# ทั้ง Frontend และ Backend ใช้ไฟล์นี้ร่วมกัน (root .env)
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================


# =============================================================================
# BACKEND - Required
# =============================================================================

# Gemini API Key (required for LLM features)
GEMINI_API_KEY=

# Number of Gunicorn workers for production (default: 4)
# Recommended: (2 x CPU cores) + 1
# WORKERS=4

# MX Proxy configuration (optional)
# MX_API_BASE_URL=http://localhost:4001
# MX_API_KEY=

# Debug flags (optional)
# DEBUG_DURATION=false


# =============================================================================
# FRONTEND - Required
# =============================================================================

# NextAuth Secret (required) - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# =============================================================================
# FRONTEND - Optional (defaults are fine for local development)
# =============================================================================

# Backend URL (default: http://localhost:8001 for local, overridden by docker-compose for containers)
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8001

# Auth URL (default: http://localhost:3000)
# AUTH_URL=http://localhost:3000

# Admin password (optional)
# ADMIN_PWD=

# Analytics configuration (optional JSON)
# NEXT_PUBLIC_ANALYTICS_CONFIG={"enabled":false,"provider":"noop"}

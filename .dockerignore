*.log
output*.log

# Temp files
temp/
tmp/
*.tmp

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Database files (handled by volumes)
*.db
*.db-shm
*.db-wal
*.duckdb

# Environment files (injected at runtime via docker-compose env_file)
# Do NOT include .env in Docker image - secrets should never be baked into images
# The frontend/.env symlink would also break inside Docker build context
.env
.env.local
.env.example
.env.*

# Documentation
docs/
*.md
!README.md

# Claude
.claude/
